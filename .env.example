# ==========================================
# RepoRAG AI Configuration Template
# ==========================================
# Copy this file to .env and fill in the values before running the application.

# --- App Settings ---
# Environment: development or production
APP_ENV=development
# Port the application runs on
APP_PORT=8000
# Enable debug mode
DEBUG=False

# --- Database ---
# PostgreSQL or SQLite connection string
# For production use: postgresql+asyncpg://user:pass@host:5432/dbname
# For local dev use SQLite: sqlite+aiosqlite:///reporag.db
DATABASE_URL=sqlite+aiosqlite:///reporag.db

# --- Neo4j Graph Database ---
# Neo4j connection URI (e.g. bolt://localhost:7687)
NEO4J_URI=bolt://localhost:7687
# Neo4j username
NEO4J_USER=neo4j
# Neo4j password (REQUIRED)
# NEO4J_PASSWORD=your_neo4j_password

# --- Qdrant Vector Store ---
# Qdrant host address
QDRANT_HOST=localhost
# Qdrant port
QDRANT_PORT=6333
# Qdrant API key if secured (leave blank for local development)
# QDRANT_API_KEY=

# --- LLM Providers ---
# OpenAI API key (REQUIRED if using OpenAI models)
# OPENAI_API_KEY=your_openai_api_key
# Anthropic API key (REQUIRED if using Anthropic models)
# ANTHROPIC_API_KEY=your_anthropic_api_key

# --- Authentication ---
# Secret key for signing JWTs (REQUIRED)
# Generate one using: openssl rand -hex 32
# JWT_SECRET=your_jwt_secret
# JWT signing algorithm
JWT_ALGORITHM=HS256
# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Google OAuth ---
# Google OAuth Client ID
# GOOGLE_CLIENT_ID=your_google_client_id
# Google OAuth Client Secret
# GOOGLE_CLIENT_SECRET=your_google_client_secret
